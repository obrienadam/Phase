; Boundary conditions for lid driven cavity test case
; - No-slip walls on all sides
; - Top wall (y+) moves with velocity (1, 0)
; - Neumann pressure boundary (zero normal gradient)

Boundaries
{
  u
  {
    *
    {
      type fixed
      value (0,0)
    }

    y+
    {
      type fixed
      value (1,0)
    }
  }

  p
  {
    *
    {
      type normal_gradient
      value 0
    }
  }
}
