; Boundary conditions for backward-facing step
; - Inlet: uniform velocity (1, 0)
; - Outlet: zero normal gradient
; - Walls: no-slip (u = 0)
; - Pressure: zero normal gradient everywhere

Boundaries
{
  u
  {
    *
    {
      type fixed
      value (0,0)
    }

    x-
    {
      type fixed
      value (1,0)
    }

    x+
    {
      type normal_gradient
      value 0
    }
  }

  p
  {
    *
    {
      type normal_gradient
      value 0
    }
  }
}
